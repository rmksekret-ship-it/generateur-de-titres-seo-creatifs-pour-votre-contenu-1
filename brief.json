ubmit', function(event) {\n            event.preventDefault();\n\n            const topic = document.getElementById('topic').value.trim();\n            const keywords = document.getElementById('keywords').value.trim().split(',').map(k => k.trim()).filter(k => k);\n            const targetAudience = document.getElementById('targetAudience').value.trim();\n            const tone = document.getElementById('tone').value;\n\n            if (!topic) {\n                alert('Veuillez saisir un sujet principal.');\n                return;\n            }\n\n            const results = generateTitles(topic, keywords, targetAudience, tone);\n            displayResults(results);\n        });\n\n        function generateTitles(topic, keywords, targetAudience, tone) {\n            const allKeywords = [topic, ...keywords, targetAudience].filter(Boolean);\n            const combinedKeywords = allKeywords.length > 0 ? allKeywords.join(' ') : topic;\n\n            const seo = [\n                `Comment ${topic} : Le Guide Complet pour les ${targetAudience || 'Experts'}`,\n                `Optimisez Votre ${topic} : Les 10 Meilleures Stratégies pour 2023`,\n                `Le Secret pour ${topic} Efficacement : Une Analyse Approfondie`,\n                `Maîtrisez le ${topic} : Trucs et Astuces Indispensables pour les ${targetAudience || 'Professionnels'}`,\n                `Pourquoi le ${topic} est Crucial pour Votre Succès en ${new Date().getFullYear()}`,\n                `Guide Ultime : ${topic} de A à Z pour ${targetAudience || 'Tous les Niveaux'}`\n            ];\n\n            const clickbait = [\n                `Choquant : La Vérité sur le ${topic} Que Personne Ne Vous Dit !`,\n                `Vous Ne Croirez Jamais Ce Que Nous Avons Découvert sur le ${topic}`,\n                `Le ${topic} : Cette Erreur Que Vous Faites Sûrement (et Comment l'Éviter)`,\n                `1 Simple Astuce Pour ${topic} Qui Va Changer Votre Vie`,\n                `Arrêtez de ${topic} Mal : Voici Pourquoi Vous Ratez Tout !`,\n                `Le Secret Bien Gardé pour ${topic} Révélé !`\n            ];\n\n            const expert = [\n                `Analyse Stratégique : Les Leviers de Croissance du ${topic}`,\n                `Prospective 2023 : Les Tendances Émergentes en ${topic}`,\n                `Décryptage : Comprendre la Complexité du ${topic} pour une Performance Optimale`,\n                `Au-Delà des Évidences : Une Approche Novatrice du ${topic}`,\n                `Synthèse Expert : L'Impact de ${topic} sur les Écosystèmes Numériques`,\n                `Méthodologie Avancée pour un ${topic} Réussi et Durable`\n            ];\n\n            const soft = [\n                `Explorez l'Univers du ${topic} : Un Voyage Inspirant`,\n                `Le ${topic} en Douceur : Prenez le Temps de Découvrir`,\n                `Votre Chemin vers un ${topic} Épanouissant : Nos Conseils Bienveillants`,\n                `Petits Bonheurs et ${topic} : Cultiver la Sérénité au Quotidien`,\n                `La Magie du ${topic} : Réinventez Votre Approche`,\n                `Un Instant de Calme pour Mieux Comprendre le ${topic}`\n            ];\n\n            const commercial = [\n                `Découvrez Notre Solution pour ${topic} : Efficacité Garantie !`,\n                `Boostez Votre Performance avec Notre Offre ${topic} Premium`,\n                `Investissez dans Votre ${topic} : Nos Produits Révolutionnaires`,\n                `Ne Manquez Pas Nos Promotions Exclusives sur le ${topic}`,\n                `Simplifiez Votre Quotidien Grâce à Notre Technologie de ${topic}`,\n                `Obtenez des Résultats Concrets avec Nos Services de ${topic}`\n            ];\n\n            // Tone adjustments (simple placeholder logic)\n            const adjustForTone = (titles, currentTone) => {\n                if (currentTone === 'enthusiastic') {\n                    return titles.map(t => `${t} !`);\n                }\n                if (currentTone === 'urgent') {\n                    return titles.map(t => `${t} Maintenant !`);\n                }\n                return titles;\n            };\n\n            return {\n                seo: adjustForTone(seo.map(t => replacePlaceholders(t, topic, allKeywords, targetAudience)), tone),\n                clickbait: adjustForTone(clickbait.map(t => replacePlaceholders(t, topic, allKeywords, targetAudience)), tone),\n                expert: adjustForTone(expert.map(t => replacePlaceholders(t, topic, allKeywords, targetAudience)), tone),\n                soft: adjustForTone(soft.map(t => replacePlaceholders(t, topic, allKeywords, targetAudience)), tone),\n                commercial: adjustForTone(commercial.map(t => replacePlaceholders(t, topic, allKeywords, targetAudience)), tone)\n            };\n        }\n\n        function replacePlaceholders(title, topic, allKeywords, targetAudience) {\n            let processedTitle = title.replace(/\\$\\{topic\\}/g, topic);\n            processedTitle = processedTitle.replace(/\\$\\{keywords\\}/g, allKeywords.filter(k => k !== topic && k !== targetAudience).join(', '));\n            processedTitle = processedTitle.replace(/\\$\\{targetAudience\\}/g, targetAudience || 'passionnés'); // Fallback for target audience\n\n            // More generic replacements if specific placeholders are not matched\n            if (processedTitle.includes('topic')) processedTitle = processedTitle.replace('topic', topic);\n            if (processedTitle.includes('keyword')) processedTitle = processedTitle.replace('keyword', allKeywords[1] || topic);\n            if (processedTitle.includes('audience')) processedTitle = processedTitle.replace('audience', targetAudience || 'lecteurs');\n\n            return processedTitle;\n        }\n\n\n        function displayResults(results) {\n            const resultDiv = document.getElementById('tool-result');\n            resultDiv.innerHTML = '<h3>Vos Titres Générés :</h3>';\n\n            for (const category in results) {\n                if (results[category].length > 0) {\n                    const groupDiv = document.createElement('div');\n                    groupDiv.className = 'result-group';\n                    groupDiv.innerHTML = `<h4>${formatCategoryName(category)}</h4><ul></ul>`;\n                    const ul = groupDiv.querySelector('ul');\n                    results[category].forEach(title => {\n                        const li = document.createElement('li');\n                        li.innerHTML = `<span>${title}</span> <button class=\"copy-button\" onclick=\"copyToClipboard(this)\">Copier</button>`;\n                        ul.appendChild(li);\n                    });\n                    resultDiv.appendChild(groupDiv);\n                }\n            }\n            resultDiv.style.display = 'flex'; // Show the results section\n            resultDiv.scrollIntoView({ behavior: 'smooth' });\n        }\n\n        function formatCategoryName(category) {\n            switch (category) {\n                case 'seo': return 'SEO (Optimisation Moteurs de Recherche)';\n                case 'clickbait': return 'Clickbait (Accrocheur)';\n                case 'expert': return 'Expert (Approfondi)';\n                case 'soft': return 'Doux (Bienveillant)';\n                case 'commercial': return 'Commercial (Vente)';\n                default: return category;\n            }\n        }\n\n        function copyToClipboard(button) {\n            const titleSpan = button.previousElementSibling;\n            const textToCopy = titleSpan.textContent;\n\n            navigator.clipboard.writeText(textToCopy).then(() => {\n                button.textContent = 'Copié !';\n                setTimeout(() => {\n                    button.textContent = 'Copier';\n                }, 1500);\n            }).catch(err => {\n                console.error('Erreur de copie: ', err);\n                alert('Échec de la copie. Veuillez copier manuellement.');\n            });\n    